val seeds = Mat.zeros(h, w, CV_8UC1)
for ((i, fp) in focusPoints.withIndex())            // семена в точках фокуса
    circle(seeds, Point(fp.cx, fp.cy), 3, Scalar(i + 1.0), -1)

var prev = seeds.clone()
repeat(maxIter) {                                    // итеративная дилатация
    val dilated = Mat(); dilate(prev, dilated, kernel)
    val stillZero = Mat(); compare(prev, Scalar(0.0), stillZero, CMP_EQ)
    dilated.copyTo(prev, stillZero)                  // заполнять только пустые
    if (countNonZero(zeroOf(prev)) == 0) return@repeat
