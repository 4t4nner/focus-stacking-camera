```kotlin
// Выбор стратегии детекции во время выполнения с откатом (fallback)
private fun initDetectors() {
    val detector = AppSettings.getDetector(this)
    if (detector == AppSettings.DETECTOR_YOLO) {
        val yolo = YoloDetector(this)
        if (yolo.initialize()) {          // ONNX-модель загружена успешно
            yoloDetector = yolo
            useYolo = true
            return
        }
        // НФТ-6: откат на резервный детектор при сбое инициализации YOLO
    }
    mlKitDetector = MlKitDetector()
    useYolo = false
}

// Единая точка вызова — вызывающий код не зависит от конкретной стратегии:
val detections: List<Detection> = if (useYolo && yoloDetector != null)
    yoloDetector!!.detect(bitmap)
else
    mlKitDetector!!.detectStream(bitmap)
```,
