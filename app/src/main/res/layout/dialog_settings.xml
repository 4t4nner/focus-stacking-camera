<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">
    <!-- ===== Режим съёмки ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Capture mode"
        android:textStyle="bold"
        android:textSize="16sp" />

    <RadioGroup
        android:id="@+id/captureModeRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="4dp">

        <RadioButton
            android:id="@+id/captureModeAutoRB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto (focus on all detected objects)" />

        <RadioButton
            android:id="@+id/captureModeManualRB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manual (tap objects to set focus)" />
    </RadioGroup>

    <!-- ==== Capture-only mode ==== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Capture Mode"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <Switch
        android:id="@+id/captureOnlySwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stop after capture (no processing)"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Saves captured frames without sending to server. Process them later via the folder button."
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33000000"
        android:layout_marginBottom="16dp" />

    <!-- ==== Detector selection ==== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Object Detector"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/detectorRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/detectorMlKitRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ML Kit"
            android:layout_marginEnd="24dp" />

        <RadioButton
            android:id="@+id/detectorYoloRB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOLO" />

    </RadioGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33000000"
        android:layout_marginBottom="16dp" />

    <!-- ==== Remote server (existing) ==== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remote Server Settings"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Switch
        android:id="@+id/remoteEnabledSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Use remote server"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Server IP / hostname"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/serverHostET"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:text="192.168.0.16" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Port"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/serverPortET"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="5000" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Status indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/status_dot_gray"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/statusTV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Not checked"
            android:textSize="13sp" />

        <Button
            android:id="@+id/testConnectionBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

</LinearLayout>